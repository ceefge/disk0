<Window x:Class="DriveScan.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="160" Width="450"
        Background="#FF1E1E2E" WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="LabelText" Foreground="White" FontSize="13" Margin="0,0,0,8"/>
        <TextBox Grid.Row="1" x:Name="InputBox" FontSize="13" Padding="6,4" Margin="0,0,0,12"
                 Background="#FF2A2A4A" Foreground="White" BorderBrush="#FF5A5A8A" CaretBrush="White"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Padding="16,4" Click="OK_Click" Background="#FF3A3A5A" Foreground="White" BorderBrush="#FF5A5A8A" Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Cancel" Padding="16,4" Click="Cancel_Click" Background="#FF3A3A5A" Foreground="White" BorderBrush="#FF5A5A8A" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
